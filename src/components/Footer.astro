---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/favicon.ico" alt="Lumino" width="28" height="28" />
          <span>Lumino</span>
        </a>
        <p class="footer-tagline">
          新一代 Rust 构建的 MIDI 编辑器，为 Black MIDI 与音乐创作打造。
        </p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>产品</h4>
          <ul>
            <li><a href="/features/">功能概览</a></li>
            <li><a href="/download/">下载</a></li>
            <li><a href="/features/performance/">性能</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>功能</h4>
          <ul>
            <li><a href="/features/editor/">MIDI 编辑器</a></li>
            <li><a href="/features/backends/">MIDI 后端</a></li>
            <li><a href="/features/collaboration/">实时协作</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>关于</h4>
          <ul>
            <li><a href="/about/">关于 Lumino</a></li>
            <li><a href="https://github.com/PenguinBMDevs/lumino-rs" target="_blank" rel="noopener noreferrer">GitHub</a></li>
            <li><a href="/about/#license">许可证</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {currentYear} PenguinBMDevs. Licensed under AGPL-3.0.</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 64px 0 32px;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 48px;
    margin-bottom: 48px;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 16px;
  }

  .footer-logo img {
    border-radius: 6px;
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 280px;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .footer-col h4 {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .footer-col a {
    display: block;
    color: var(--text-secondary);
    font-size: 0.95rem;
    padding: 6px 0;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--gold-light);
  }

  .footer-bottom {
    padding-top: 24px;
    border-top: 1px solid var(--border);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
