---
---

<section class="hero">
  <div class="hero-bg">
    <img src="/hero-screenshot.png" alt="" aria-hidden="true" />
    <div class="hero-overlay"></div>
  </div>
  <div class="container hero-inner">
    <div class="hero-content">
      <span class="tag">Rust 构建 · 跨平台 · GPU 加速</span>
      <h1 class="hero-title">
        为 Black MIDI 打造的
        <span class="accent-text">新一代 MIDI 编辑器</span>
      </h1>
      <p class="hero-description">
        Lumino 使用 Rust 构建，基于 wgpu 与 iced 技术栈，提供低延迟、高性能的跨平台 MIDI 编辑体验。多轨编辑、音符绘制、力度调整与实时协作，一气呵成。
      </p>
      <div class="hero-actions">
        <a href="https://github.com/PenguinBMDevs/lumino-rs/releases" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          免费下载
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        </a>
        <a href="/features/" class="btn btn-secondary">探索功能</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">< 1ms</span>
          <span class="stat-label">音频延迟</span>
        </div>
        <div class="stat">
          <span class="stat-value">跨平台</span>
          <span class="stat-label">Windows / macOS / Linux</span>
        </div>
        <div class="stat">
          <span class="stat-value">GPU</span>
          <span class="stat-label">wgpu 加速渲染</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 140px 0 80px;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(6px);
    scale: 1.05;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: 
      linear-gradient(180deg, rgba(10, 10, 10, 0.65) 0%, rgba(10, 10, 10, 0.82) 100%);
    backdrop-filter: blur(2px);
  }

  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .hero-content {
    max-width: 720px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 24px 0 28px;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--gold);
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .hero-content {
      text-align: center;
      max-width: 100%;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
