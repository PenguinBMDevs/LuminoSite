---
---

<section class="hero">
  <div class="hero-glow"></div>
  <div class="container hero-inner">
    <div class="hero-content">
      <span class="tag">Rust 构建 · 跨平台 · GPU 加速</span>
      <h1 class="hero-title">
        为 Black MIDI 打造的
        <span class="accent-text">新一代 MIDI 编辑器</span>
      </h1>
      <p class="hero-description">
        Lumino 使用 Rust 构建，基于 wgpu 与 iced 技术栈，提供低延迟、高性能的跨平台 MIDI 编辑体验。多轨编辑、音符绘制、力度调整与实时协作，一气呵成。
      </p>
      <div class="hero-actions">
        <a href="/download/" class="btn btn-primary">
          免费下载
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
        </a>
        <a href="/features/" class="btn btn-secondary">探索功能</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">< 1ms</span>
          <span class="stat-label">音频延迟</span>
        </div>
        <div class="stat">
          <span class="stat-value">跨平台</span>
          <span class="stat-label">Windows / macOS / Linux</span>
        </div>
        <div class="stat">
          <span class="stat-value">GPU</span>
          <span class="stat-label">wgpu 加速渲染</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="editor-preview">
        <div class="editor-header">
          <div class="window-dots">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <span class="editor-title">Lumino Editor</span>
        </div>
        <div class="editor-body">
          <div class="piano-roll">
            <div class="note n1"></div>
            <div class="note n2"></div>
            <div class="note n3"></div>
            <div class="note n4"></div>
            <div class="note n5"></div>
            <div class="note n6"></div>
            <div class="note n7"></div>
            <div class="note n8"></div>
          </div>
          <div class="velocity-lane">
            <div class="velocity-bar"></div>
            <div class="velocity-bar"></div>
            <div class="velocity-bar"></div>
            <div class="velocity-bar"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 140px 0 80px;
    overflow: hidden;
    background: 
      radial-gradient(ellipse at 20% 30%, rgba(184, 115, 51, 0.15) 0%, transparent 45%),
      radial-gradient(ellipse at 80% 70%, rgba(212, 175, 55, 0.1) 0%, transparent 45%),
      var(--bg-primary);
  }

  .hero-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(184, 115, 51, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-content {
    max-width: 640px;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 24px 0 28px;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .hero-stats {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--gold);
  }

  .stat-label {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .editor-preview {
    width: 100%;
    max-width: 520px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 
      0 32px 64px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(184, 115, 51, 0.1);
  }

  .editor-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border);
  }

  .window-dots {
    display: flex;
    gap: 6px;
  }

  .window-dots span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .window-dots span:first-child { background: #ff5f57; }
  .window-dots span:nth-child(2) { background: #febc2e; }
  .window-dots span:nth-child(3) { background: #28c840; }

  .editor-title {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .editor-body {
    padding: 24px;
  }

  .piano-roll {
    position: relative;
    height: 180px;
    background: 
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 23px,
        rgba(255, 255, 255, 0.03) 23px,
        rgba(255, 255, 255, 0.03) 24px
      );
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    margin-bottom: 16px;
    overflow: hidden;
  }

  .note {
    position: absolute;
    height: 18px;
    border-radius: 4px;
    background: var(--accent-gradient);
    box-shadow: 0 2px 8px rgba(184, 115, 51, 0.3);
    animation: pulse 2.5s ease-in-out infinite;
  }

  .note.n1 { top: 24px; left: 8%; width: 22%; animation-delay: 0s; }
  .note.n2 { top: 72px; left: 18%; width: 16%; animation-delay: 0.3s; }
  .note.n3 { top: 48px; left: 42%; width: 28%; animation-delay: 0.6s; }
  .note.n4 { top: 96px; left: 56%; width: 18%; animation-delay: 0.9s; }
  .note.n5 { top: 120px; left: 12%; width: 14%; animation-delay: 1.2s; }
  .note.n6 { top: 72px; left: 74%; width: 20%; animation-delay: 1.5s; }
  .note.n7 { top: 144px; left: 36%; width: 24%; animation-delay: 1.8s; }
  .note.n8 { top: 24px; left: 64%; width: 12%; animation-delay: 2.1s; }

  @keyframes pulse {
    0%, 100% { opacity: 0.85; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.05); }
  }

  .velocity-lane {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 80px;
    padding: 16px;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  .velocity-bar {
    flex: 1;
    background: var(--accent-gradient);
    border-radius: 4px 4px 0 0;
    opacity: 0.8;
  }

  .velocity-bar:nth-child(1) { height: 45%; }
  .velocity-bar:nth-child(2) { height: 78%; }
  .velocity-bar:nth-child(3) { height: 60%; }
  .velocity-bar:nth-child(4) { height: 92%; }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-content {
      max-width: 100%;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-visual {
      order: -1;
    }

    .editor-preview {
      max-width: 420px;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
