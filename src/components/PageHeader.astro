---
export interface Props {
  title: string;
  description: string;
  tag?: string;
}

const { title, description, tag } = Astro.props;
---

<section class="page-header">
  <div class="container">
    {tag && <span class="tag">{tag}</span>}
    <h1>{title}</h1>
    <p>{description}</p>
  </div>
</section>
