---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PageHeader from '../../../components/PageHeader.astro';

const backends = [
  {
    name: 'KDMAPI',
    fullName: 'KDMAPI / OmniMIDI',
    desc: '专为 Black MIDI 与高音符密度场景优化，绕过传统 winmm 限制，提供极低的 MIDI 输出延迟与更高的并发事件吞吐能力。',
    badge: 'Windows',
    highlight: true,
  },
  {
    name: 'winmm',
    fullName: 'Windows Multimedia API',
    desc: '系统级原生 MIDI 输出接口，兼容性最广，适合普通监听与通用回放场景，无需额外驱动。',
    badge: 'Windows',
    highlight: false,
  },
  {
    name: 'xsynth',
    fullName: 'xsynth Realtime',
    desc: '纯软件合成器后端，基于 SoundFont 实时渲染，适合无硬件 MIDI 设备时的快速预览与跨平台一致音色。',
    badge: 'Cross-platform',
    highlight: true,
  }
];
---

<Layout 
  title="MIDI 后端 - Lumino" 
  description="Lumino 同时支持 KDMAPI、winmm 与 xsynth 多种 MIDI I/O 后端，满足创作、监听与回放的不同需求。"
>
  <Header />
  <main>
    <PageHeader
      tag="Backends"
      title="MIDI 后端"
      description="多后端并行支持，根据场景自由切换输出方式，兼顾低延迟、兼容性与跨平台一致性。"
    />

    <section class="content-section">
      <div class="container">
        <div class="backend-intro">
          <div class="intro-text">
            <span class="tag">I/O 架构</span>
            <h2 class="section-title">一个编辑器，<br/><span class="accent-text">多种输出选择</span></h2>
            <p class="lead">
              Lumino 的 MIDI I/O 层不绑定单一后端。无论是 Black MIDI 玩家追求的极限延迟，还是普通用户需要的即开即用，Lumino 都能在设置中一键切换。
            </p>
          </div>
          <div class="backend-graphic">
            <div class="io-node editor">Lumino Editor</div>
            <div class="io-arrows">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="io-outputs">
              <div class="io-node out">KDMAPI</div>
              <div class="io-node out">winmm</div>
              <div class="io-node out">xsynth</div>
            </div>
          </div>
        </div>

        <div class="backend-cards">
          {backends.map((b) => (
            <div class={`backend-card ${b.highlight ? 'featured' : ''}`}>
              <div class="backend-header">
                <h3>{b.name}</h3>
                <span class="backend-badge">{b.badge}</span>
              </div>
              <p class="backend-full">{b.fullName}</p>
              <p class="backend-desc">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="content-section bg-secondary">
      <div class="container">
        <div class="section-header">
          <span class="tag">Realtime</span>
          <h2 class="section-title">实时合成与回放</h2>
          <p class="section-subtitle">实时引擎负责将编辑器中的音符事件准时送达所选后端，确保编辑与聆听同步。</p>
        </div>
        <div class="spec-grid">
          <div class="spec-card">
            <div class="value">xsynth</div>
            <div class="label">纯软件 SoundFont 合成</div>
          </div>
          <div class="spec-card">
            <div class="value">事件驱动</div>
            <div class="label">音符触发直达后端</div>
          </div>
          <div class="spec-card">
            <div class="value">低延迟</div>
            <div class="label">毫秒级事件调度</div>
          </div>
          <div class="spec-card">
            <div class="value">可切换</div>
            <div class="label">运行时切换后端</div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .backend-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
    margin-bottom: 80px;
  }

  .intro-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .backend-graphic {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
    padding: 40px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .io-node {
    padding: 16px 28px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    text-align: center;
  }

  .io-node.editor {
    width: 100%;
    background: var(--accent-gradient);
    color: #0a0a0a;
  }

  .io-arrows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .io-arrows span {
    width: 2px;
    height: 16px;
    background: var(--copper);
  }

  .io-outputs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    width: 100%;
  }

  .io-node.out {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .backend-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .backend-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    transition: all 0.25s ease;
  }

  .backend-card:hover {
    transform: translateY(-4px);
    border-color: rgba(184, 115, 51, 0.4);
  }

  .backend-card.featured {
    border-color: rgba(184, 115, 51, 0.4);
    background: linear-gradient(180deg, rgba(184, 115, 51, 0.06) 0%, var(--bg-card) 100%);
  }

  .backend-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .backend-header h3 {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .backend-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(184, 115, 51, 0.12);
    color: var(--gold-light);
    border: 1px solid rgba(184, 115, 51, 0.25);
  }

  .backend-full {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .backend-desc {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .bg-secondary {
    background: var(--bg-secondary);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
    text-align: center;
    align-items: center;
  }

  @media (max-width: 900px) {
    .backend-intro {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .backend-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
