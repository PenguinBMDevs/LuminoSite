---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import PageHeader from '../../../components/PageHeader.astro';

const metrics = [
  { value: '8 线程', label: '并行批量移动' },
  { value: '10,000+', label: 'SoA 音符阈值' },
  { value: '< 1ms', label: '目标音频延迟' },
  { value: 'wgpu', label: '跨平台 GPU 抽象' },
];
---

<Layout 
  title="性能渲染 - Lumino" 
  description="Lumino 使用 wgpu 实现跨平台 GPU 加速渲染，结合 SoA 批量存储与多线程算法，胜任超高密度 Black MIDI 工程。"
>
  <Header />
  <main>
    <PageHeader
      tag="Performance"
      title="性能渲染"
      description="从 CPU 数据布局到 GPU 管线，每一层都为高密度音符与低延迟体验优化。"
    />

    <section class="content-section">
      <div class="container">
        <div class="perf-grid">
          <div class="perf-content">
            <span class="tag">GPU 加速</span>
            <h2 class="section-title">wgpu 驱动的<br/><span class="accent-text">跨平台渲染管线</span></h2>
            <p class="lead">
              Lumino 基于 wgpu 构建渲染后端，可在 Windows、macOS 与 Linux 上复用同一套 GPU 管线。无论是音符矩形、网格背景还是视口滚动，渲染批次都经过合并优化，显著降低 CPU 开销。
            </p>
            <ul class="feature-list">
              <li>iced 数据驱动 UI 框架，声明式界面与原生体验兼得</li>
              <li>Canvas 级别的自定义绘制，钢琴卷帘完全可控</li>
              <li>批处理渲染，减少 Draw Call 数量</li>
              <li>winit 窗口抽象，统一事件循环与输入处理</li>
            </ul>
          </div>
          <div class="perf-visual">
            <div class="perf-card gpu">
              <div class="perf-icon">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="4" y="4" width="16" height="16" rx="2"/>
                  <path d="M8 8h8M8 12h8M8 16h5"/>
                </svg>
              </div>
              <h3>GPU Rendering</h3>
              <div class="perf-bars">
                <div class="bar-row"><span>Draw Calls</span><div class="bar low" style="width: 24%"></div></div>
                <div class="bar-row"><span>CPU Overhead</span><div class="bar low" style="width: 32%"></div></div>
                <div class="bar-row"><span>Frame Time</span><div class="bar low" style="width: 18%"></div></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="content-section bg-secondary">
      <div class="container">
        <div class="section-header">
          <span class="tag">Data Layout</span>
          <h2 class="section-title">SoA 批量存储，多线程并行</h2>
          <p class="section-subtitle">当音符数量超过阈值时，Lumino 自动切换到结构体数组（SoA）存储，结合 Rayon 风格并行处理。</p>
        </div>
        <div class="spec-grid">
          {metrics.map(m => (
            <div class="spec-card">
              <div class="value">{m.value}</div>
              <div class="label">{m.label}</div>
            </div>
          ))}
        </div>
        <div class="code-block">
          <div class="code-header">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="code-title">note_store.rs</span>
          </div>
          <pre><code><span class="comment">// 当音符数超过阈值时启用 SoA 批量操作</span>
<span class="keyword">pub const</span> NOTE_STORE_THRESHOLD: <span class="type">usize</span> = <span class="number">10_000</span>;

<span class="comment">// 批量移动：8 线程并行，16M 音符 50% 18ms</span>
note_store.batch_move_parallel(offset, selected);

<span class="comment">// 批量删除：O(N) 单次遍历</span>
note_store.delete_selected(indices);

<span class="comment">// 批量插入：无 realloc，1ms/1000 音符</span>
note_store.insert_bulk(notes);</code></pre>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .perf-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .perf-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .perf-visual {
    display: flex;
    justify-content: center;
  }

  .perf-card {
    width: 100%;
    max-width: 420px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 40px;
    box-shadow: var(--shadow-lg);
  }

  .perf-card.gpu {
    border-color: rgba(184, 115, 51, 0.25);
  }

  .perf-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    background: rgba(184, 115, 51, 0.1);
    color: var(--gold);
    margin-bottom: 24px;
  }

  .perf-card h3 {
    font-size: 1.5rem;
    margin-bottom: 24px;
  }

  .perf-bars {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .bar-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .bar {
    height: 8px;
    border-radius: 4px;
    background: var(--accent-gradient);
    flex-shrink: 0;
  }

  .bg-secondary {
    background: var(--bg-secondary);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
    text-align: center;
    align-items: center;
  }

  .code-block {
    margin-top: 48px;
    background: #0e0e0e;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    background: #161616;
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .dot:nth-child(1) { background: #ff5f57; }
  .dot:nth-child(2) { background: #febc2e; }
  .dot:nth-child(3) { background: #28c840; }

  .code-title {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  pre {
    margin: 0;
    padding: 24px;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  code {
    color: var(--text-secondary);
  }

  .comment { color: #6a9955; }
  .keyword { color: #569cd6; }
  .type { color: #4ec9b0; }
  .number { color: #b5cea8; }

  @media (max-width: 900px) {
    .perf-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
