---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';

const platforms = [
  {
    os: 'Windows',
    archs: ['x86_64', 'aarch64'],
    note: '推荐 Windows 10 / 11，含 KDMAPI 与 winmm 后端',
  },
  {
    os: 'macOS',
    archs: ['x86_64', 'Apple Silicon'],
    note: '使用 xsynth 后端预览',
  },
  {
    os: 'Linux',
    archs: ['x86_64', 'aarch64'],
    note: 'AppImage、deb、rpm 已提供',
  },
];

const requirements = [
  'Rust 1.94.0+（从源码构建时）',
  'Windows：MSVC / Visual Studio Build Tools',
  'macOS：Xcode Command Line Tools',
  'Linux：GCC/Clang、pkg-config',
];
---

<Layout 
  title="下载 - Lumino" 
  description="下载 Lumino 最新版本。支持 Windows、macOS 与 Linux，亦可通过 cargo 从源码构建。"
>
  <Header />
  <main>
    <PageHeader
      tag="Download"
      title="下载 Lumino"
      description="选择适合你的平台，开始使用为 Black MIDI 打造的现代 MIDI 编辑器。"
    />

    <section class="content-section">
      <div class="container">
        <div class="download-hero">
          <div class="download-card">
            <div class="download-info">
              <span class="version-tag">v0.2.0-crates-io-preview1</span>
              <h2>最新稳定版本</h2>
              <p>包含 MIDI 编辑器、多后端预览、自动化轨道与配置持久化等核心能力。</p>
              <a href="https://github.com/PenguinBMDevs/lumino-rs/releases" target="_blank" rel="noopener noreferrer" class="btn btn-primary download-btn">
                前往 GitHub Releases
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
            <div class="download-platforms">
              {platforms.map((p) => (
                <div class="platform-row">
                  <div class="platform-name">
                    <strong>{p.os}</strong>
                    <span>{p.archs.join(' / ')}</span>
                  </div>
                  <div class="platform-note">{p.note}</div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="build-section">
          <div class="section-header">
            <span class="tag">Source Build</span>
            <h2 class="section-title">从源码构建</h2>
            <p class="section-subtitle">Lumino 是开源项目，可通过 cargo 在本地编译运行。</p>
          </div>
          <div class="req-grid">
            <div class="req-card">
              <h4>前置要求</h4>
              <ul class="feature-list">
                {requirements.map(r => <li>{r}</li>)}
              </ul>
            </div>
            <div class="code-card">
              <div class="code-header">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="code-title">Shell</span>
              </div>
              <pre><code>git clone https://github.com/PenguinBMDevs/lumino-rs.git
cd lumino-rs
cargo build --release
cargo run --release</code></pre>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .download-hero {
    margin-bottom: 80px;
  }

  .download-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    padding: 48px;
    background: 
      radial-gradient(circle at 90% 10%, rgba(184, 115, 51, 0.1) 0%, transparent 50%),
      var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .download-info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .version-tag {
    align-self: flex-start;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gold);
    background: rgba(184, 115, 51, 0.12);
    border: 1px solid rgba(184, 115, 51, 0.25);
  }

  .download-info h2 {
    font-size: 2rem;
    font-weight: 700;
  }

  .download-info p {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .download-btn {
    margin-top: 8px;
    align-self: flex-start;
  }

  .download-platforms {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .platform-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
  }

  .platform-name {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .platform-name strong {
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .platform-name span {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  .platform-note {
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-align: right;
  }

  .build-section {
    padding-top: 80px;
    border-top: 1px solid var(--border);
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 48px;
    text-align: center;
    align-items: center;
  }

  .req-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 32px;
  }

  .req-card {
    padding: 32px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .req-card h4 {
    font-size: 0.875rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  .code-card {
    background: #0e0e0e;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 14px 18px;
    background: #161616;
    border-bottom: 1px solid var(--border);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--text-muted);
  }

  .dot:nth-child(1) { background: #ff5f57; }
  .dot:nth-child(2) { background: #febc2e; }
  .dot:nth-child(3) { background: #28c840; }

  .code-title {
    margin-left: auto;
    font-size: 0.8rem;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
  }

  pre {
    margin: 0;
    padding: 24px;
    overflow-x: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .download-card {
      grid-template-columns: 1fr;
    }
    .req-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
